<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SportMax — Интернет-магазин спортивных товаров</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #0a0a0a;
      --surface: #111111;
      --card: #161616;
      --border: #222222;
      --accent: #e8ff00;
      --accent2: #ff3c00;
      --text: #f0f0f0;
      --muted: #666;
      --radius: 8px;
    }
    * { margin:0; padding:0; box-sizing:border-box; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      line-height: 1.6;
    }
    a { text-decoration: none; color: inherit; }
    button { cursor: pointer; border: none; outline: none; font-family: inherit; }

    /* ─── NAVBAR ─── */
    nav {
      position: sticky; top: 0; z-index: 100;
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 40px;
      display: flex; align-items: center; justify-content: space-between;
      height: 64px;
    }
    .logo {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 28px;
      letter-spacing: 3px;
      color: var(--accent);
    }
    .logo span { color: var(--text); }
    .nav-links { display: flex; gap: 32px; }
    .nav-links a {
      font-size: 13px; font-weight: 500; letter-spacing: 1px;
      text-transform: uppercase; color: var(--muted);
      transition: color .2s;
    }
    .nav-links a:hover, .nav-links a.active { color: var(--text); }
    .nav-right { display: flex; align-items: center; gap: 16px; }
    .cart-btn {
      background: var(--accent); color: #000;
      border-radius: 6px; padding: 8px 20px;
      font-size: 13px; font-weight: 700; letter-spacing: .5px;
      display: flex; align-items: center; gap: 8px;
      transition: opacity .2s;
    }
    .cart-btn:hover { opacity: .85; }
    .cart-count {
      background: #000; color: var(--accent);
      border-radius: 50%; width: 20px; height: 20px;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700;
    }
    .sync-btn {
      background: transparent; color: var(--muted);
      border: 1px solid var(--border); border-radius: 6px;
      padding: 7px 14px; font-size: 12px; font-weight: 500;
      display: flex; align-items: center; gap: 6px;
      transition: all .2s;
    }
    .sync-btn:hover { border-color: var(--accent); color: var(--accent); }
    .sync-icon { width:14px; height:14px; }

    /* ─── HERO ─── */
    .hero {
      position: relative; overflow: hidden;
      min-height: 520px;
      display: flex; align-items: center;
      padding: 80px 40px;
      background: linear-gradient(135deg, #0a0a0a 0%, #111 60%, #0f1a00 100%);
    }
    .hero::before {
      content: '';
      position: absolute; right: -80px; top: -80px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(232,255,0,.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-grid {
      position: absolute; inset: 0;
      background-image:
        linear-gradient(rgba(232,255,0,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(232,255,0,.04) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-content { position: relative; max-width: 640px; }
    .hero-tag {
      display: inline-block;
      background: rgba(232,255,0,.12); color: var(--accent);
      font-size: 11px; font-weight: 600; letter-spacing: 2px;
      text-transform: uppercase; padding: 5px 12px; border-radius: 4px;
      margin-bottom: 20px;
    }
    .hero h1 {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 80px; line-height: .9;
      letter-spacing: 2px; margin-bottom: 24px;
    }
    .hero h1 em { color: var(--accent); font-style: normal; }
    .hero p { color: var(--muted); font-size: 16px; max-width: 460px; margin-bottom: 36px; }
    .hero-btns { display: flex; gap: 12px; }
    .btn-primary {
      background: var(--accent); color: #000;
      padding: 14px 32px; border-radius: 6px;
      font-weight: 700; font-size: 14px; letter-spacing: .5px;
      transition: opacity .2s;
    }
    .btn-primary:hover { opacity: .85; }
    .btn-secondary {
      background: transparent; color: var(--text);
      border: 1px solid var(--border);
      padding: 14px 32px; border-radius: 6px;
      font-weight: 600; font-size: 14px;
      transition: border-color .2s;
    }
    .btn-secondary:hover { border-color: var(--muted); }
    .hero-stats {
      position: absolute; right: 40px; bottom: 40px;
      display: flex; gap: 40px;
    }
    .stat { text-align: right; }
    .stat-val {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 42px; line-height: 1; color: var(--accent);
    }
    .stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }

    /* ─── INTEGRATION BANNER ─── */
    .integration-bar {
      background: var(--surface);
      border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
      padding: 16px 40px;
      display: flex; align-items: center; justify-content: space-between;
      gap: 20px;
    }
    .integration-info { display: flex; align-items: center; gap: 12px; }
    .integration-dot { width:8px; height:8px; border-radius:50%; background: #3be03b; box-shadow: 0 0 8px #3be03b; animation: pulse 2s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .integration-text { font-size: 13px; color: var(--muted); }
    .integration-text strong { color: var(--text); }
    .last-sync { font-size: 12px; color: var(--muted); }

    /* ─── SECTION COMMON ─── */
    section { padding: 64px 40px; }
    .section-header { margin-bottom: 36px; display: flex; align-items: flex-end; justify-content: space-between; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: 40px; letter-spacing: 2px; }
    .section-sub { color: var(--muted); font-size: 14px; margin-top: 4px; }
    .see-all { font-size: 13px; color: var(--accent); font-weight: 600; letter-spacing: .5px; transition: opacity .2s; }
    .see-all:hover { opacity: .7; }

    /* ─── CATEGORIES ─── */
    .categories { background: var(--surface); }
    .cat-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
    .cat-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px 16px;
      text-align: center; cursor: pointer;
      transition: border-color .2s, transform .2s;
      display: flex; flex-direction: column; align-items: center; gap: 10px;
    }
    .cat-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .cat-card.active { border-color: var(--accent); background: rgba(232,255,0,.05); }
    .cat-icon { font-size: 32px; }
    .cat-name { font-size: 13px; font-weight: 600; letter-spacing: .5px; }
    .cat-count { font-size: 11px; color: var(--muted); }

    /* ─── PRODUCTS ─── */
    .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    .product-card {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden;
      transition: border-color .2s, transform .2s;
      cursor: pointer;
    }
    .product-card:hover { border-color: var(--border); transform: translateY(-4px); }
    .product-img {
      background: var(--surface);
      height: 200px; display: flex; align-items: center; justify-content: center;
      font-size: 72px; position: relative;
    }
    .badge {
      position: absolute; top: 12px; left: 12px;
      font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
      padding: 4px 8px; border-radius: 4px;
    }
    .badge-new { background: var(--accent); color: #000; }
    .badge-sale { background: var(--accent2); color: #fff; }
    .badge-hit { background: #7c3aed; color: #fff; }
    .product-body { padding: 16px; }
    .product-brand { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 2px; margin-bottom: 4px; }
    .product-name { font-weight: 600; font-size: 14px; margin-bottom: 8px; }
    .product-desc { font-size: 12px; color: var(--muted); margin-bottom: 12px; line-height: 1.5; }
    .product-footer { display: flex; align-items: center; justify-content: space-between; }
    .product-price { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; }
    .product-price .old { font-size: 14px; color: var(--muted); text-decoration: line-through; margin-left: 6px; font-family: 'Inter', sans-serif; }
    .add-to-cart {
      background: var(--accent); color: #000;
      border-radius: 6px; padding: 8px 14px;
      font-size: 12px; font-weight: 700;
      transition: opacity .2s;
    }
    .add-to-cart:hover { opacity: .8; }
    .stock-low { font-size: 11px; color: #ff9900; margin-top: 8px; }
    .stock-ok  { font-size: 11px; color: #3be03b; margin-top: 8px; }

    /* ─── HOW IT WORKS ─── */
    .how { background: var(--surface); }
    .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
    .step {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 28px 20px; text-align: center;
    }
    .step-num {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 48px; color: var(--accent); line-height: 1; margin-bottom: 12px;
    }
    .step-title { font-weight: 700; font-size: 14px; margin-bottom: 8px; }
    .step-desc { font-size: 13px; color: var(--muted); }

    /* ─── CART MODAL ─── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.7); z-index: 200;
      align-items: flex-start; justify-content: flex-end;
    }
    .modal-overlay.open { display: flex; }
    .cart-panel {
      background: var(--surface); width: 420px; height: 100vh;
      border-left: 1px solid var(--border);
      display: flex; flex-direction: column;
      animation: slideIn .25s ease;
    }
    @keyframes slideIn { from{transform:translateX(100%)} to{transform:translateX(0)} }
    .cart-header {
      padding: 24px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .cart-header h2 { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; }
    .close-btn {
      background: var(--card); border: 1px solid var(--border);
      color: var(--text); border-radius: 6px; padding: 6px 12px; font-size: 16px;
    }
    .cart-items { flex: 1; overflow-y: auto; padding: 20px; }
    .cart-item {
      display: flex; gap: 14px; padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }
    .cart-item-img { font-size: 40px; width: 56px; text-align: center; }
    .cart-item-info { flex: 1; }
    .cart-item-name { font-weight: 600; font-size: 13px; margin-bottom: 4px; }
    .cart-item-price { font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: var(--accent); }
    .cart-item-qty { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
    .qty-btn { background: var(--card); border: 1px solid var(--border); color: var(--text); width: 26px; height: 26px; border-radius: 4px; font-size: 14px; }
    .cart-footer {
      padding: 20px; border-top: 1px solid var(--border);
    }
    .cart-total { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
    .cart-total-label { font-size: 14px; color: var(--muted); }
    .cart-total-val { font-family: 'Bebas Neue', sans-serif; font-size: 28px; }
    .checkout-btn {
      width: 100%; background: var(--accent); color: #000;
      padding: 14px; border-radius: 6px;
      font-weight: 700; font-size: 15px; letter-spacing: .5px;
      transition: opacity .2s;
    }
    .checkout-btn:hover { opacity: .85; }
    .empty-cart { text-align: center; padding: 60px 20px; color: var(--muted); }
    .empty-cart div { font-size: 48px; margin-bottom: 16px; }

    /* ─── TOAST ─── */
    .toast {
      position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(120%);
      background: #1a1a1a; border: 1px solid var(--accent);
      color: var(--text); padding: 12px 24px; border-radius: 8px;
      font-size: 13px; font-weight: 500; z-index: 300;
      transition: transform .3s ease;
    }
    .toast.show { transform: translateX(-50%) translateY(0); }

    /* ─── FOOTER ─── */
    footer {
      background: var(--surface); border-top: 1px solid var(--border);
      padding: 40px; text-align: center;
      color: var(--muted); font-size: 12px;
    }
    footer .logo { font-size: 22px; margin-bottom: 8px; }

    /* ─── FILTER BAR ─── */
    .filter-bar {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 28px; flex-wrap: wrap;
    }
    .filter-label { font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
    .filter-chip {
      background: var(--card); border: 1px solid var(--border);
      color: var(--muted); border-radius: 20px; padding: 5px 14px;
      font-size: 12px; font-weight: 500; cursor: pointer;
      transition: all .2s;
    }
    .filter-chip:hover, .filter-chip.active { background: rgba(232,255,0,.1); border-color: var(--accent); color: var(--accent); }

    /* 1C Schema */
    .schema-block {
      background: var(--card); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 24px; margin-top: 40px;
    }
    .schema-title {
      font-family: 'Bebas Neue', sans-serif; font-size: 22px;
      letter-spacing: 2px; margin-bottom: 16px; color: var(--accent);
    }
    .schema-code {
      background: #0d0d0d; border: 1px solid #222;
      border-radius: 6px; padding: 16px;
      font-family: 'Courier New', monospace; font-size: 12px;
      color: #a8e06e; overflow-x: auto; line-height: 1.7;
    }
    .schema-code .key { color: #64b5f6; }
    .schema-code .val { color: #a8e06e; }
    .schema-code .str { color: #f48fb1; }
    .schema-code .num { color: #ffcc02; }

    /* RESPONSIVE */
    @media(max-width:900px) {
      .products-grid { grid-template-columns: repeat(2, 1fr); }
      .cat-grid { grid-template-columns: repeat(3, 1fr); }
      .steps { grid-template-columns: repeat(2, 1fr); }
      .hero h1 { font-size: 52px; }
      .hero-stats { display: none; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav>
  <div class="logo">Sport<span>Max</span></div>
  <div class="nav-links">
    <a href="#catalog" class="active">Каталог</a>
    <a href="#how">Как купить</a>
    <a href="#about">О нас</a>
  </div>
  <div class="nav-right">
    <button class="sync-btn" onclick="syncFrom1C()">
      <svg class="sync-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M1 4v6h6M23 20v-6h-6"/>
        <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4-4.64 4.36A9 9 0 0 1 3.51 15"/>
      </svg>
      Sync 1С
    </button>
    <button class="cart-btn" onclick="openCart()">
      🛒 Корзина <span class="cart-count" id="cartCount">0</span>
    </button>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-grid"></div>
  <div class="hero-content">
    <div class="hero-tag">⚡ Интеграция с 1С Розница KZ</div>
    <h1>Твой спорт —<br><em>твои правила</em></h1>
    <p>Профессиональное снаряжение для любого вида спорта. Актуальные остатки и цены напрямую из 1С.</p>
    <div class="hero-btns">
      <a href="#catalog" class="btn-primary">Смотреть каталог</a>
      <a href="#how" class="btn-secondary">Как это работает</a>
    </div>
  </div>
  <div class="hero-stats">
    <div class="stat"><div class="stat-val">340+</div><div class="stat-label">Товаров</div></div>
    <div class="stat"><div class="stat-val">1С</div><div class="stat-label">Интеграция</div></div>
    <div class="stat"><div class="stat-val">24/7</div><div class="stat-label">Поддержка</div></div>
  </div>
</div>

<!-- INTEGRATION BAR -->
<div class="integration-bar">
  <div class="integration-info">
    <div class="integration-dot"></div>
    <div class="integration-text">
      <strong>1С:Розница KZ</strong> — синхронизация активна. Данные о товарах получены через HTTP-сервис 1С.
    </div>
  </div>
  <div class="last-sync" id="lastSync">Последняя синхронизация: только что</div>
</div>

<!-- CATEGORIES -->
<section class="categories" id="catalog">
  <div class="section-header">
    <div>
      <div class="section-title">Категории</div>
      <div class="section-sub">Выберите вид спорта</div>
    </div>
  </div>
  <div class="cat-grid" id="catGrid">
    <div class="cat-card active" onclick="filterCat('all', this)">
      <div class="cat-icon">🏆</div>
      <div class="cat-name">Все товары</div>
      <div class="cat-count" id="cntAll">0 товаров</div>
    </div>
    <div class="cat-card" onclick="filterCat('Футбол', this)">
      <div class="cat-icon">⚽</div>
      <div class="cat-name">Футбол</div>
      <div class="cat-count" id="cntFootball">0 товаров</div>
    </div>
    <div class="cat-card" onclick="filterCat('Фитнес', this)">
      <div class="cat-icon">🏋️</div>
      <div class="cat-name">Фитнес</div>
      <div class="cat-count" id="cntFitness">0 товаров</div>
    </div>
    <div class="cat-card" onclick="filterCat('Бег', this)">
      <div class="cat-icon">🏃</div>
      <div class="cat-name">Бег</div>
      <div class="cat-count" id="cntRun">0 товаров</div>
    </div>
    <div class="cat-card" onclick="filterCat('Единоборства', this)">
      <div class="cat-icon">🥊</div>
      <div class="cat-name">Единоборства</div>
      <div class="cat-count" id="cntMMA">0 товаров</div>
    </div>
  </div>
</section>

<!-- PRODUCTS -->
<section id="products">
  <div class="section-header">
    <div>
      <div class="section-title">Каталог товаров</div>
      <div class="section-sub">Данные синхронизированы из 1С:Розница</div>
    </div>
    <a class="see-all" href="#">Все товары →</a>
  </div>

  <div class="filter-bar">
    <span class="filter-label">Сортировка:</span>
    <button class="filter-chip active" onclick="sortProducts('default', this)">По умолчанию</button>
    <button class="filter-chip" onclick="sortProducts('price-asc', this)">Цена ↑</button>
    <button class="filter-chip" onclick="sortProducts('price-desc', this)">Цена ↓</button>
    <button class="filter-chip" onclick="sortProducts('new', this)">Новинки</button>
  </div>

  <div class="products-grid" id="productsGrid">
    <!-- filled by JS -->
  </div>

  <!-- 1C JSON Schema reference -->
  <div class="schema-block">
    <div class="schema-title">📦 Структура данных из 1С (HTTP-сервис)</div>
    <div class="schema-code" id="jsonExample"></div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="how" id="how">
  <div class="section-header">
    <div>
      <div class="section-title">Схема интеграции</div>
      <div class="section-sub">Как сайт взаимодействует с 1С:Розница KZ</div>
    </div>
  </div>
  <div class="steps">
    <div class="step">
      <div class="step-num">01</div>
      <div class="step-title">HTTP-запрос с сайта</div>
      <div class="step-desc">Сайт отправляет GET-запрос на HTTP-сервис 1С для получения актуального списка товаров и остатков</div>
    </div>
    <div class="step">
      <div class="step-num">02</div>
      <div class="step-title">Обработка в 1С</div>
      <div class="step-desc">Расширение конфигурации формирует JSON-ответ с товарами, ценами и остатками из базы 1С:Розница KZ</div>
    </div>
    <div class="step">
      <div class="step-num">03</div>
      <div class="step-title">Обновление каталога</div>
      <div class="step-desc">Сайт парсит JSON и обновляет карточки товаров: цены, наличие и описания синхронизируются автоматически</div>
    </div>
    <div class="step">
      <div class="step-num">04</div>
      <div class="step-title">Заказ → 1С</div>
      <div class="step-desc">При оформлении заказа POST-запрос создаёт документ «Заказ клиента» в 1С и резервирует товар на складе</div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer id="about">
  <div class="logo">Sport<span>Max</span></div>
  <p>Дипломный проект: Интернет-магазин с интеграцией 1С:Розница KZ</p>
  <p style="margin-top:8px">© 2024 SportMax. Все права защищены.</p>
</footer>

<!-- CART MODAL -->
<div class="modal-overlay" id="cartModal">
  <div class="cart-panel">
    <div class="cart-header">
      <h2>Корзина</h2>
      <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-items" id="cartItems">
      <div class="empty-cart"><div>🛒</div>Корзина пуста</div>
    </div>
    <div class="cart-footer">
      <div class="cart-total">
        <span class="cart-total-label">Итого:</span>
        <span class="cart-total-val" id="cartTotal">0 ₸</span>
      </div>
      <button class="checkout-btn" onclick="checkout()">Оформить заказ</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ─── DATA (эмулирует JSON от 1С) ───
const products1C = [
  { id: "00001", code: "ADIDA-F101", name: "Футбольные бутсы Predator", brand: "Adidas", cat: "Футбол", price: 42000, oldPrice: 52000, stock: 12, emoji: "👟", badge: "sale", desc: "Профессиональные бутсы для газонного поля. Верх из синтетической кожи.", isNew: false },
  { id: "00002", code: "NIKE-B202",  name: "Футбольный мяч Strike",    brand: "Nike",   cat: "Футбол", price: 18500, oldPrice: null, stock: 34, emoji: "⚽", badge: "hit",  desc: "Тренировочный мяч ФИФА Quality Pro. Размер 5.", isNew: false },
  { id: "00003", code: "REEBOK-D303",name: "Гантели Pro Set 20кг",     brand: "Reebok", cat: "Фитнес", price: 28000, oldPrice: null, stock: 5,  emoji: "🏋️", badge: "new",  desc: "Разборные гантели. Сталь с покрытием. Вес: 2×10 кг.", isNew: true },
  { id: "00004", code: "ASICS-R404", name: "Кроссовки Gel-Nimbus 25",  brand: "Asics",  cat: "Бег",    price: 65000, oldPrice: 78000, stock: 8,  emoji: "🥿", badge: "sale", desc: "Амортизирующие кроссовки для длинных дистанций. Технология FlyteFoam.", isNew: false },
  { id: "00005", code: "EVERLAST-M505", name: "Боксёрские перчатки Pro", brand: "Everlast", cat: "Единоборства", price: 22000, oldPrice: null, stock: 15, emoji: "🥊", badge: null, desc: "Перчатки для спарринга. 16 OZ. Натуральная кожа.", isNew: false },
  { id: "00006", code: "PUMA-F606",  name: "Форма футбольная домашняя", brand: "Puma",  cat: "Футбол", price: 31000, oldPrice: null, stock: 20, emoji: "👕", badge: "new",  desc: "Командная форма. Футболка + шорты. Технология DryCell.", isNew: true },
  { id: "00007", code: "KETTLER-G707", name: "Скакалка Speed Rope",    brand: "Kettler",cat: "Фитнес", price: 8500,  oldPrice: null, stock: 42, emoji: "🪢", badge: null,  desc: "Профессиональная скакалка для кроссфита. Ручки из алюминия.", isNew: false },
  { id: "00008", code: "UA-R808",    name: "Компрессионные тайтсы",    brand: "Under Armour", cat: "Бег", price: 19000, oldPrice: 24000, stock: 3, emoji: "🩲", badge: "sale", desc: "Тайтсы для бега. Поддержка мышц. UPF 50+.", isNew: false },
];

let cart = [];
let currentCat = 'all';
let currentSort = 'default';

function getFiltered() {
  let list = [...products1C];
  if (currentCat !== 'all') list = list.filter(p => p.cat === currentCat);
  if (currentSort === 'price-asc') list.sort((a,b) => a.price - b.price);
  if (currentSort === 'price-desc') list.sort((a,b) => b.price - a.price);
  if (currentSort === 'new') list = [...list.filter(p=>p.isNew), ...list.filter(p=>!p.isNew)];
  return list;
}

function renderProducts() {
  const grid = document.getElementById('productsGrid');
  const list = getFiltered();
  grid.innerHTML = list.map(p => `
    <div class="product-card" onclick="openProduct(${p.id})">
      <div class="product-img">
        ${p.emoji}
        ${p.badge ? `<span class="badge badge-${p.badge}">${p.badge==='sale'?'Скидка':p.badge==='new'?'Новинка':'Хит'}</span>` : ''}
      </div>
      <div class="product-body">
        <div class="product-brand">${p.brand}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <div class="product-price">
            ${p.price.toLocaleString('ru')} ₸
            ${p.oldPrice ? `<span class="old">${p.oldPrice.toLocaleString('ru')} ₸</span>` : ''}
          </div>
          <button class="add-to-cart" onclick="event.stopPropagation(); addToCart('${p.id}')">+ В корзину</button>
        </div>
        <div class="${p.stock <= 5 ? 'stock-low' : 'stock-ok'}">
          ${p.stock <= 5 ? `⚠ Осталось ${p.stock} шт.` : `✓ В наличии: ${p.stock} шт.`}
        </div>
        <div style="font-size:10px;color:var(--muted);margin-top:4px">Код 1С: ${p.code}</div>
      </div>
    </div>
  `).join('');
}

function renderCounts() {
  document.getElementById('cntAll').textContent = products1C.length + ' товаров';
  document.getElementById('cntFootball').textContent = products1C.filter(p=>p.cat==='Футбол').length + ' товара';
  document.getElementById('cntFitness').textContent = products1C.filter(p=>p.cat==='Фитнес').length + ' товара';
  document.getElementById('cntRun').textContent = products1C.filter(p=>p.cat==='Бег').length + ' товара';
  document.getElementById('cntMMA').textContent = products1C.filter(p=>p.cat==='Единоборства').length + ' товара';
}

function filterCat(cat, el) {
  currentCat = cat;
  document.querySelectorAll('.cat-card').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderProducts();
}

function sortProducts(sort, el) {
  currentSort = sort;
  document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  renderProducts();
}

// ─── CART ───
function addToCart(id) {
  const p = products1C.find(x => x.id === id);
  if (!p) return;
  const existing = cart.find(x => x.id === id);
  if (existing) existing.qty++;
  else cart.push({ ...p, qty: 1 });
  updateCartCount();
  showToast(`✓ ${p.name} добавлен в корзину`);
}

function updateCartCount() {
  const count = cart.reduce((s, x) => s + x.qty, 0);
  document.getElementById('cartCount').textContent = count;
}

function openCart() {
  document.getElementById('cartModal').classList.add('open');
  renderCart();
}

function closeCart() {
  document.getElementById('cartModal').classList.remove('open');
}

function renderCart() {
  const el = document.getElementById('cartItems');
  if (!cart.length) {
    el.innerHTML = '<div class="empty-cart"><div>🛒</div>Корзина пуста</div>';
    document.getElementById('cartTotal').textContent = '0 ₸';
    return;
  }
  el.innerHTML = cart.map(item => `
    <div class="cart-item">
      <div class="cart-item-img">${item.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">${(item.price * item.qty).toLocaleString('ru')} ₸</div>
        <div class="cart-item-qty">
          <button class="qty-btn" onclick="changeQty('${item.id}', -1)">−</button>
          <span style="font-size:13px;font-weight:600">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty('${item.id}', 1)">+</button>
        </div>
      </div>
    </div>
  `).join('');
  const total = cart.reduce((s, x) => s + x.price * x.qty, 0);
  document.getElementById('cartTotal').textContent = total.toLocaleString('ru') + ' ₸';
}

function changeQty(id, delta) {
  const item = cart.find(x => x.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) cart = cart.filter(x => x.id !== id);
  updateCartCount();
  renderCart();
}

function checkout() {
  if (!cart.length) { showToast('Корзина пуста!'); return; }
  showToast('✓ Заказ оформлен! Данные отправлены в 1С:Розница');
  cart = [];
  updateCartCount();
  renderCart();
  closeCart();
}

// ─── SYNC 1C ───
function syncFrom1C() {
  showToast('🔄 Синхронизация с 1С...');
  setTimeout(() => {
    document.getElementById('lastSync').textContent = 'Последняя синхронизация: только что';
    renderProducts();
    showToast('✓ Данные из 1С обновлены');
  }, 1500);
}

// ─── TOAST ───
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ─── JSON SCHEMA ───
function renderJsonExample() {
  const example = {
    "metadata": {
      "source": "1С:Розница KZ",
      "version": "2.3",
      "syncTime": new Date().toISOString()
    },
    "items": [
      {
        "Код": "ADIDA-F101",
        "Наименование": "Футбольные бутсы Predator",
        "Категория": "Футбол",
        "Цена": 42000,
        "Валюта": "KZT",
        "ОстатокСклад": 12,
        "Единица": "шт"
      }
    ]
  };
  const str = JSON.stringify(example, null, 2);
  const highlighted = str
    .replace(/"([^"]+)":/g, '<span class="key">"$1"</span>:')
    .replace(/: "([^"]+)"/g, ': <span class="str">"$1"</span>')
    .replace(/: (\d+)/g, ': <span class="num">$1</span>');
  document.getElementById('jsonExample').innerHTML = highlighted;
}

// close modal on overlay click
document.getElementById('cartModal').addEventListener('click', function(e) {
  if (e.target === this) closeCart();
});

// ─── INIT ───
renderCounts();
renderProducts();
renderJsonExample();
</script>
</body>
</html>
